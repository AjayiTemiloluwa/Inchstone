generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id       String  @id @default(uuid())
  userId   String
  layer    Int // 1: Yearly (Yearning), 2: Quarterly (Quest), 3: Monthly (Milestone), 4: Weekly (Win), 5: Daily (Deed)
  parentId String?
  parent   Item?   @relation("ItemToItem", fields: [parentId], references: [id])
  children Item[]  @relation("ItemToItem")

  title       String
  description String?
  weight      Float   @default(1.0) // percentage weight for weighted scoring
  status      String  @default("active") // active, archived
  completed   Boolean @default(false)
  progress    Float   @default(0) // 0-100 partial progress
  category    String?

  // Date ranges for calendar periods
  startDate DateTime?
  endDate   DateTime?

  // Recurrence
  isRecurring       Boolean   @default(false)
  recurrencePattern String?
  recurrenceEnd     DateTime?

  // Layer-specific metadata
  theme           String?
  focusQuestion   String?
  anchorScripture String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes            Note[]
  reviews          Review[]
  partnerLinks     PartnerLink[]
  financialEntries FinancialEntry[]
  tasks            Task[]
}

model Task {
  id                String    @id @default(uuid())
  userId            String
  deedId            String
  deed              Item      @relation(fields: [deedId], references: [id], onDelete: Cascade)
  title             String
  weight            Float     @default(1.0)
  progress          Float     @default(0)
  completed         Boolean   @default(false)
  date              DateTime
  scheduledTime     DateTime?
  isRecurring       Boolean   @default(false)
  recurrencePattern String?
  recurrenceEnd     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  itemId    String?
  item      Item?    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id           String   @id @default(uuid())
  userId       String
  itemId       String?
  item         Item?    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  periodType   String
  periodStart  DateTime
  mood         Int?
  energy       Int?
  reflection   String?
  wins         String?
  misses       String?
  tomorrowTop3 Json?
  partnerNotes String?
  stats        Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Partner {
  id        String   @id @default(uuid())
  userId    String
  name      String
  email     String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partnerLinks PartnerLink[]
  nudges       Nudge[]
}

model PartnerLink {
  id        String   @id @default(uuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  partnerId String
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([itemId, partnerId])
}

model Nudge {
  id         String   @id @default(uuid())
  partnerId  String
  partner    Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  senderId   String
  receiverId String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model UserCategory {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String
  icon      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id        String   @id @default(uuid())
  userId    String
  title     String
  startTime DateTime
  endTime   DateTime
  type      String   @default("event")
  completed Boolean  @default(false)
  score     Int?
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyScore {
  id             String   @id @default(uuid())
  userId         String
  date           DateTime
  totalTasks     Int      @default(0)
  completedTasks Int      @default(0)
  score          Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, date])
}

model FinancialEntry {
  id          String   @id @default(uuid())
  userId      String
  deedId      String?
  deed        Item?    @relation(fields: [deedId], references: [id], onDelete: SetNull)
  entryDate   DateTime
  type        String
  amount      Float
  currency    String   @default("USD")
  category    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserToken {
  id           String    @id @default(uuid())
  userId       String
  provider     String
  accessToken  String
  refreshToken String?
  expiryDate   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PendingSuggestion {
  id             String   @id @default(uuid())
  fromUserId     String
  toUserId       String
  itemId         String?
  suggestedTitle String
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
