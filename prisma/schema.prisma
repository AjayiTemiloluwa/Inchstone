generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id     String @id @default(uuid())
  userId String
  // 0: Year, 1: Category, 2: Yearly Goal, 3: Quarterly Goal, 4: Monthly Goal, 5: Weekly Goal, 6: Daily Goal
  layer  Int

  parentId String?
  parent   Item?   @relation("ItemToItem", fields: [parentId], references: [id], onDelete: Cascade)
  children Item[]  @relation("ItemToItem")

  title       String
  description String?
  weight      Float   @default(1.0) // percentage weight
  status      String  @default("active") // active, archived
  completed   Boolean @default(false)
  progress    Float   @default(0) // 0-100 score/progress
  scoreMode   String  @default("auto") // "auto" | "manual" - whether score is calculated from children or manually set
  category    String? // Keep for legacy string categories if needed, but Category is now a node in the tree

  // Date ranges for calendar periods (e.g., for quarters, months, weeks, days)
  startDate DateTime?
  endDate   DateTime?

  // Recurrence
  isRecurring       Boolean   @default(false)
  recurrencePattern String?
  recurrenceEnd     DateTime?

  // Layer-specific metadata
  theme           String?
  focusQuestion   String?
  anchorScripture String?
  reflection      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes            Note[]
  reviews          Review[]
  partnerLinks     PartnerLink[]
  financialEntries FinancialEntry[]

  tasks Task[] @relation("GoalTasks")
}

model Task {
  id     String @id @default(uuid())
  userId String

  goalId String
  goal   Item   @relation("GoalTasks", fields: [goalId], references: [id], onDelete: Cascade)

  categoryId String? // Denormalized reference to the Category item

  title     String
  weight    Float   @default(1.0)
  progress  Float   @default(0)
  completed Boolean @default(false)

  date              DateTime // Target execution date
  startTime         DateTime? // 24h scheduling start
  endTime           DateTime? // 24h scheduling end
  estimatedDuration Int? // in minutes
  actualDuration    Int? // in minutes
  priority          String? // "high", "medium", "low"
  isFrog            Boolean   @default(false)
  isHabit           Boolean   @default(false)

  scheduledTime     DateTime? // Legacy field, keeping in case used elsewhere
  isRecurring       Boolean   @default(false)
  recurrencePattern String?
  recurrenceEnd     DateTime?
  color             String? // Hex color for timeline display (e.g. "#d4af37")
  reflection        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Note {
  id          String    @id @default(uuid())
  userId      String
  itemId      String?
  item        Item?     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  title       String
  content     String
  attachments Json?     // Array of { name, type, size, dataUrl }
  date        DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, date])
}

model Review {
  id           String   @id @default(uuid())
  userId       String
  itemId       String?
  item         Item?    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  periodType   String
  periodStart  DateTime
  mood         Int?
  energy       Int?
  reflection   String?
  wins         String?
  misses       String?
  tomorrowTop3 Json?
  partnerNotes String?
  stats        Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Partner {
  id        String   @id @default(uuid())
  userId    String
  name      String
  email     String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partnerLinks PartnerLink[]
  nudges       Nudge[]
}

model PartnerLink {
  id        String   @id @default(uuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  partnerId String
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([itemId, partnerId])
}

model Nudge {
  id         String   @id @default(uuid())
  partnerId  String
  partner    Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  senderId   String
  receiverId String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// UserCategory is removed since Layer 1 Items will now handle categories.

model Event {
  id        String   @id @default(uuid())
  userId    String
  title     String
  startTime DateTime
  endTime   DateTime
  type      String   @default("event")
  completed Boolean  @default(false)
  score     Int?
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DailyScore {
  id             String   @id @default(uuid())
  userId         String
  date           DateTime
  totalTasks     Int      @default(0)
  completedTasks Int      @default(0)
  score          Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, date])
}

model FinancialEntry {
  id          String   @id @default(uuid())
  userId      String
  itemId      String?
  item        Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
  entryDate   DateTime
  type        String
  amount      Float
  currency    String   @default("USD")
  category    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserToken {
  id           String    @id @default(uuid())
  userId       String
  provider     String
  accessToken  String
  refreshToken String?
  expiryDate   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, provider])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tracker {
  id        String   @id @default(uuid())
  userId    String
  title     String
  date      DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}

model PendingSuggestion {
  id             String   @id @default(uuid())
  fromUserId     String
  toUserId       String
  itemId         String?
  suggestedTitle String
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
